{
  "name": "mowa-eval",
  "version": "0.1.0",
  "description": "A test runner for prompts. Score them, and fail the PR when one regresses.",
  "license": "MIT",
  "type": "module",
  "keywords": ["prompt-engineering", "llm", "prompts", "prompt-testing", "evals", "evaluation", "ci", "github-action", "ai"],
  "homepage": "https://github.com/bluesky-tech-inc/mowa-eval#readme",
  "repository": { "type": "git", "url": "git+https://github.com/bluesky-tech-inc/mowa-eval.git" },
  "bugs": { "url": "https://github.com/bluesky-tech-inc/mowa-eval/issues" },
  "engines": { "node": ">=20" },
  "bin": { "mowa": "./dist/cli.js" },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "mowa": "tsx src/cli/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/google": "^3.0.58",
    "@ai-sdk/openai": "^3.0.50",
    "ai": "^6.0.146",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
